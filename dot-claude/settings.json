{
  "enabledPlugins": {
    "Notion@claude-plugins-official": true,
    "playwright@claude-plugins-official": true
  },
  "env": {
    "CLAUDE_CODE_EXPERIMENTAL_AGENT_TEAMS": "1",
    "GEMINI_API_KEY": "",
    "GEMINI_MODEL": "gemini-3-pro-image-preview",
    "GEMINI_API_URL": "https://generativelanguage.googleapis.com/v1beta/models"
  },
  "permissions": {
    "allow": [
      "Bash(cat:*)",
      "Bash(ls:*)",
      "Bash(find:*)",
      "Bash(grep:*)",
      "Bash(head:*)",
      "Bash(tail:*)",
      "Bash(wc:*)",
      "Bash(git status:*)",
      "Bash(git log:*)",
      "Bash(git diff:*)",
      "Bash(git branch:*)",
      "Bash(npm test:*)",
      "Bash(npx tsc --noEmit:*)",
      "Bash(pnpm test:*)",
      "Bash(pnpm build:*)",
      "Bash(pytest:*)",
      "Bash(go test:*)",
      "Bash(go build:*)",
      "Bash(pm2 logs:*)",
      "Bash(pm2 status:*)"
    ],
    "deny": [
      "Bash(rm -rf /)",
      "Bash(git push --force)",
      "Bash(DROP DATABASE)",
      "Bash(DROP TABLE)"
    ]
  },
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "echo '=== Session Context ===' && git branch --show-current 2>/dev/null && echo '---' && git status --short 2>/dev/null && echo '---' && if [ -d dev/active ]; then echo 'Active tasks:' && ls dev/active/ 2>/dev/null; fi && echo '---' && if [ -f TODO.md ]; then head -20 TODO.md; fi"
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/scripts/skill-activator.sh"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Write|Edit|MultiEdit",
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/scripts/track-edits.sh"
          }
        ]
      }
    ],
    "Stop": [],
    "PreCompact": [
      {
        "matcher": "auto",
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/scripts/backup-transcript.sh"
          }
        ]
      }
    ]
  }
}
